{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "shell:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "updater:default",
    "process:default",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:8765/**" }
      ]
    }
  ]
}
